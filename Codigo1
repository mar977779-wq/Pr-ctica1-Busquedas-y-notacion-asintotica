#include <bits/stdc++.h>
using namespace std;
using namespace chrono;

// ==================== ALGORITMOS DE BÚSQUEDA ====================

int busquedaLineal(const vector<int>& a, int x) {
    for (size_t i = 0; i < a.size(); ++i) {
        if (a[i] == x) return (int)i;
    }
    return -1;
}

int busquedaBinaria(const vector<int>& a, int x) {
    int l = 0, r = (int)a.size() - 1;
    while (l <= r) {
        int m = l + (r - l) / 2;
        if (a[m] == x) return m;
        else if (a[m] < x) l = m + 1;
        else r = m - 1;
    }
    return -1;
}

int busquedaExponencial(const vector<int>& a, int x) {
    if (a.empty()) return -1;
    if (a[0] == x) return 0;
    
    int i = 1;
    int n = (int)a.size();
    while (i < n && a[i] < x) {
        i <<= 1;  // duplica el rango
    }
    
    int l = i / 2;
    int r = min(i, n - 1);
    
    // Búsqueda binaria en el rango [l, r]
    while (l <= r) {
        int m = l + (r - l) / 2;
        if (a[m] == x) return m;
        else if (a[m] < x) l = m + 1;
        else r = m - 1;
    }
    return -1;
}

int busquedaInterpolacion(const vector<int>& a, int x) {
    int low = 0, high = (int)a.size() - 1;
    
    while (low <= high && x >= a[low] && x <= a[high]) {
        if (a[low] == a[high]) {
            return (a[low] == x) ? low : -1;
        }
        
        // Fórmula de interpolación
        long long pos = low + (long long)((double)(high - low) * 
                        (double)(x - a[low]) / (double)(a[high] - a[low]));
        
        if (pos < low || pos > high) break;
        
        if (a[pos] == x) return (int)pos;
        if (a[pos] < x) low = (int)pos + 1;
        else high = (int)pos - 1;
    }
    return -1;
}

// ==================== MEDICIÓN DE TIEMPOS ====================

template <typename Func>
double medirTiempo(const vector<int>& arr, const vector<int>& queries, Func buscador) {
    auto t0 = high_resolution_clock::now();
    volatile long long checksum = 0;  // evita optimizaciones del compilador
    
    for (int x : queries) {
        checksum += buscador(arr, x);
    }
    
    auto t1 = high_resolution_clock::now();
    duration<double, milli> ms = t1 - t0;
    
    return ms.count() / (double)queries.size();  // ms por búsqueda
}

// ==================== GENERACIÓN DE DATOS ====================

vector<int> generarUniformeOrdenado(int n) {
    vector<int> arr(n);
    iota(arr.begin(), arr.end(), 0);
    return arr;
}

vector<int> generarSesgadoOrdenado(int n, mt19937& rng) {
    vector<int> arr(n);
    uniform_real_distribution<double> prob(0, 1);
    
    for (int i = 0; i < n; i++) {
        double u = prob(rng);
        if (u < 0.8) {
            // 80% concentrado en rango estrecho [0, 0.1n)
            arr[i] = uniform_int_distribution<int>(0, (int)(0.1 * n))(rng);
        } else {
            // 20% disperso en rango amplio [0.1n, 5n)
            arr[i] = uniform_int_distribution<int>((int)(0.1 * n), 5 * n)(rng);
        }
    }
    sort(arr.begin(), arr.end());
    return arr;
}

vector<int> generarDesordenado(int n, mt19937& rng) {
    vector<int> arr = generarUniformeOrdenado(n);
    shuffle(arr.begin(), arr.end(), rng);
    return arr;
}

// ==================== GENERACIÓN DE CONSULTAS ====================

vector<int> generarConsultas(const vector<int>& base, mt19937& rng) {
    vector<int> queries;
    queries.reserve(1000);
    int n = base.size();
    
    // 70% hits (elementos que sí existen)
    uniform_int_distribution<int> idx(0, n - 1);
    for (int i = 0; i < 700; i++) {
        queries.push_back(base[idx(rng)]);
    }
    
    // 30% misses (elementos que no existen)
    for (int i = 0; i < 300; i++) {
        queries.push_back(10 * n + i);
    }
    
    // Mezclar para evitar sesgos de localidad
    shuffle(queries.begin(), queries.end(), rng);
    return queries;
}

// ==================== FUNCIÓN PRINCIPAL ====================

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    
    mt19937 rng(123);  // semilla fija para reproducibilidad
    vector<int> ns = {10000, 100000, 500000};
    
    cout << fixed << setprecision(6);
    cout << "n\tDataset\t\tLineal(ms)\tBinaria(ms)\tExponencial(ms)\tInterpolacion(ms)\n";
    cout << string(90, '-') << "\n";
    
    for (int n : ns) {
        // Generar datasets
        vector<int> uniforme = generarUniformeOrdenado(n);
        vector<int> sesgado = generarSesgadoOrdenado(n, rng);
        vector<int> desordenado = generarDesordenado(n, rng);
        
        // Generar consultas para cada dataset
        vector<int> q_uniforme = generarConsultas(uniforme, rng);
        vector<int> q_sesgado = generarConsultas(sesgado, rng);
        vector<int> q_desordenado = generarConsultas(desordenado, rng);
        
        // ===== UNIFORME ORDENADO =====
        double t_lineal_uni = medirTiempo(uniforme, q_uniforme, busquedaLineal);
        double t_binaria_uni = medirTiempo(uniforme, q_uniforme, busquedaBinaria);
        double t_exp_uni = medirTiempo(uniforme, q_uniforme, busquedaExponencial);
        double t_interp_uni = medirTiempo(uniforme, q_uniforme, busquedaInterpolacion);
        
        cout << n << "\tUniforme ord.\t" << t_lineal_uni << "\t" 
             << t_binaria_uni << "\t" << t_exp_uni << "\t\t" << t_interp_uni << "\n";
        
        // ===== SESGADO ORDENADO =====
        double t_lineal_ses = medirTiempo(sesgado, q_sesgado, busquedaLineal);
        double t_binaria_ses = medirTiempo(sesgado, q_sesgado, busquedaBinaria);
        double t_exp_ses = medirTiempo(sesgado, q_sesgado, busquedaExponencial);
        double t_interp_ses = medirTiempo(sesgado, q_sesgado, busquedaInterpolacion);
        
        cout << n << "\tSesgado ord.\t" << t_lineal_ses << "\t" 
             << t_binaria_ses << "\t" << t_exp_ses << "\t\t" << t_interp_ses << "\n";
        
        // ===== DESORDENADO =====
        double t_lineal_des = medirTiempo(desordenado, q_desordenado, busquedaLineal);
        
        cout << n << "\tDesordenado\t" << t_lineal_des << "\t---\t---\t\t---\n";
        cout << string(90, '-') << "\n";
    }
    
    return 0;
}
